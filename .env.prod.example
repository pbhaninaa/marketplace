# Copy to .env.prod for docker compose — never commit real secrets.

# --- Public frontend URL (no trailing slash) ---
PUBLIC_APP_BASE_URL=https://your-domain.com

# --- PostgreSQL ---
PROD_DB_NAME=marketplace
PROD_DB_USER=marketplace
PROD_DB_PASSWORD=

# --- Security ---
APP_JWT_SECRET=

# --- CORS (comma-separated if multiple origins) ---
PROD_CORS_ORIGINS=https://your-domain.com

# --- Email (SendGrid) ---
SENDGRID_API_KEY=
EMAIL_DOMAIN=yourdomain.com
# Optional fallback when domain authentication is not configured:
EMAIL_FROM=

# --- Payments label (EFT/CASH in-app; no card gateway required) ---
PROD_PAYMENT_PROVIDER=stub

# --- Platform bank (provider subscription EFT) ---
APP_BANK_NAME=
APP_BANK_ACCOUNT_NAME=
APP_BANK_ACCOUNT_NUMBER=
APP_BANK_BRANCH_CODE=
APP_BANK_REFERENCE_HINT=Use your Provider Name as reference

# --- Subscription pricing (ZAR / month) ---
APP_SUBSCRIPTION_BASIC_MONTHLY=199
APP_SUBSCRIPTION_PREMIUM_MONTHLY=499

# --- Frontend build (empty when nginx proxies /api on same domain) ---
VITE_API_BASE=
