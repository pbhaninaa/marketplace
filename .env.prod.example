# Copy to .env.prod and fill in real values

# Public URL where users access the frontend (same domain will proxy /api to backend)
PUBLIC_APP_BASE_URL=https://your-domain.com

# Postgres (production)
PROD_DB_NAME=marketplace
PROD_DB_USER=marketplace
PROD_DB_PASSWORD=change-me

# JWT secret (MIN 32+ chars; use a strong random secret)
APP_JWT_SECRET=change-me-please-use-a-strong-random-secret-at-least-32-chars

# Payments provider (optional)
PROD_PAYMENT_PROVIDER=stripe

