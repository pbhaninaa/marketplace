{
  "name": "marketplace-mobile",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=sitDebug --appId com.agrimarketplace.sit",
    "android:sit": "react-native run-android --mode=sitDebug --appId com.agrimarketplace.sit",
    "android:uat": "react-native run-android --mode=uatDebug --appId com.agrimarketplace.uat",
    "android:prod": "react-native run-android --mode=prodDebug",
    "android:release": "cd android && gradlew assembleUatRelease",
    "android:release:sit": "cd android && gradlew assembleSitRelease",
    "android:release:uat": "cd android && gradlew assembleUatRelease",
    "android:release:prod": "cd android && gradlew assembleProdRelease",
    "ios": "react-native run-ios",
    "ios:release:sit": "node ../../scripts/build-ipa.mjs sit",
    "ios:release:uat": "node ../../scripts/build-ipa.mjs uat",
    "ios:release:prod": "node ../../scripts/build-ipa.mjs prod",
    "ios:release:all": "node ../../scripts/build-ipa.mjs all",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-documents/picker": "^12.0.1",
    "@react-native/new-app-screen": "0.81.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^2.0.1",
    "axios": "^1.6.0",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-maps": "^1.25.3",
    "react-native-permissions": "^5.4.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.15.2",
    "react-native-vector-icons": "^10.0.3",
    "react-native-webview": "^13.16.0",
    "react-redux": "^9.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.0",
    "@react-native/eslint-config": "0.81.0",
    "@react-native/metro-config": "0.81.0",
    "@react-native/typescript-config": "0.81.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
